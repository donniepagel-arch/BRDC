{
  "hosting": {
    "site": "fortheloveofdarts-fd8e0",
    "public": "sites/fortheloveofdarts-public",
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
    "headers": [
      { "source": "**/*.js", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
      { "source": "**/*.html", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
      { "source": "**/*.css", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
      { "source": "/rookies", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] },
      { "source": "/rookies/**", "headers": [{ "key": "Cache-Control", "value": "no-cache" }] }
    ],
    "rewrites": [
      { "source": "/rookies/dashboard", "destination": "/rookies/pages/home-vnext.html" },
      { "source": "/rookies/dashboard/**", "destination": "/rookies/pages/home-vnext.html" },
      { "source": "/rookies", "destination": "/rookies/index.html" },
      { "source": "**", "destination": "/index.html" }
    ]
  }
}
