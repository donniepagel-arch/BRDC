{
  "hosting": [
    {
      "site": "brdc-v2",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.css",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/dashboard", "destination": "/pages/dashboard.html" },
        { "source": "/profile", "destination": "/pages/player-profile.html" },
        { "source": "/messages", "destination": "/pages/messages.html" },
        { "source": "/friends", "destination": "/pages/friends.html" },
        { "source": "/events", "destination": "/pages/events-hub.html" },
        { "source": "/scorer", "destination": "/pages/game-setup.html" },
        { "source": "/match-hub", "destination": "/pages/match-hub.html" },
        { "source": "/league", "destination": "/pages/league-view.html" },
        { "source": "/register", "destination": "/pages/register.html" },
        { "source": "/login", "destination": "/index.html" },
        { "source": "**", "destination": "/index.html" }
      ]
    },
    {
      "site": "burningriverdarts",
      "public": "public",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "headers": [
        {
          "source": "**/*.js",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.html",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        },
        {
          "source": "**/*.css",
          "headers": [
            { "key": "Cache-Control", "value": "no-cache" }
          ]
        }
      ],
      "rewrites": [
        { "source": "/dashboard", "destination": "/pages/dashboard.html" },
        { "source": "/profile", "destination": "/pages/player-profile.html" },
        { "source": "/messages", "destination": "/pages/messages.html" },
        { "source": "/friends", "destination": "/pages/friends.html" },
        { "source": "/events", "destination": "/pages/events-hub.html" },
        { "source": "/scorer", "destination": "/pages/game-setup.html" },
        { "source": "/match-hub", "destination": "/pages/match-hub.html" },
        { "source": "/league", "destination": "/pages/league-view.html" },
        { "source": "/register", "destination": "/pages/register.html" },
        { "source": "/login", "destination": "/index.html" },
        { "source": "**", "destination": "/index.html" }
      ]
    }
  ]
}
